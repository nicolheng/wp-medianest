# MongoDB connection URI
MONGO_URI=mongodb://<username>:<password>@host:port/dbname

# Session secret used to sign cookies
SESSION_SECRET=your_session_secret_here

# Environment and server settings
NODE_ENV=development
PORT=5000

# OAuth / third-party keys
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URL of the frontend client (used for CORS, redirects)
CLIENT_URL=http://localhost:8081

# External API keys
TMDB_KEY=your_tmdb_read_token
LASTFM_KEY=your_lastfm_api_key
NYT_KEY=your_nyt_api_key
GOOGLE_BOOKS_KEY=your_google_books_api_key

