# TMDB read token (used by client-side TMDB requests)
VITE_TMDB_READ_TOKEN=your_tmdb_read_token

# LastFM API key
VITE_LASTFM_API_KEY=your_lastfm_api_key

# New York Times Books API key
VITE_NYT_BOOKS_API_KEY=your_nyt_api_key

# Backend API base URL (used by frontend to call backend endpoints)
VITE_API_BASE_URL=http://localhost:5000

